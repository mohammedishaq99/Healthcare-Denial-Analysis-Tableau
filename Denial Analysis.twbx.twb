      </column>
      <column caption='Denial Rate' datatype='real' name='[Calculation_1444431139184643]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1444431138496513])/ COUNT([ClaimID])' />
      </column>
      <column caption='Approval Rate' datatype='real' name='[Calculation_1444431139545092]' role='measure' type='quantitative'>
