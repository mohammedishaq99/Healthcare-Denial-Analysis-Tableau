      <column caption='Denied' datatype='integer' name='[Calculation_1444431138496513]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [ClaimStatus]= &quot;Denied&quot; THEN 1 ELSE 0 END' />
